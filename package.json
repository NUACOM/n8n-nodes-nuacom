{
  "name": "@nuacom/n8n-nodes-nuacom",
  "version": "0.1.3",
  "description": "NUACOM community nodes for n8n — webhook triggers and REST API actions",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://nuacom.com",
  "author": {
    "name": "NUACOM",
    "email": "support@nuacom.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NUACOM/n8n-nodes-nuacom"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy:icons",
    "copy:icons": "copyfiles -u 0 \"nodes/**/*.svg\" \"credentials/**/*.svg\" dist/",
    "dev": "tsc --watch",
    "lint": "n8n-node lint",
    "prepublishOnly": "npm run build",
    "release": "n8n-node release"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/NuacomApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/NuacomTrigger/NuacomTrigger.node.js",
      "dist/nodes/Nuacom/Nuacom.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@n8n/node-cli": "^0.31.0",
    "@types/node": "^20.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "n8n-workflow": "*",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
